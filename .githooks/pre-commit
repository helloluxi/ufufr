#!/bin/sh
set -e

SHA=$(git rev-parse --short HEAD)
DATE=$(date +%Y.%m.%d)
VERSION="${DATE}-${SHA}"

# Stamp the short SHA into sw.js so the service worker is byte-different
# on every commit (guarantees the browser picks up the new version).
sed -i "s/const CACHE_NAME = '[^']*'/const CACHE_NAME = 'helloluxi-ufufr-${SHA}'/" sw.js

# Regenerate version.js (shared by the UI footer; self works in both
# window and service-worker globals).
cat > version.js <<EOF
// Auto-generated by .githooks/pre-commit. Do not edit by hand.
self.BLD_VERSION = '${VERSION}';
EOF

git add sw.js version.js
